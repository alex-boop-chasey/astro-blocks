---
import PageLayout from '~/layouts/PageLayout.astro';

const categories = [
  {
    title: 'Hero Components',
    description: 'Landing page hero sections with strong first-screen layouts.',
    href: '/heros',
    count: '6 blocks',
  },
  {
    title: 'Feature Components',
    description: 'Product feature sections for explaining benefits and capabilities.',
    href: '/features',
    count: '12 blocks',
  },
  {
    title: 'Bento Components',
    description: 'Asymmetric grid sections for dense, scannable product stories.',
    href: '/bentos',
    count: '3 blocks',
  },
  {
    title: 'Pricing Components',
    description: 'Pricing sections for plans, packages, and conversion flows.',
    href: '/pricing',
    count: '5 blocks',
  },
  {
    title: 'Contact Components',
    description: 'Contact sections for support, sales, and lead capture pages.',
    href: '/contact',
    count: '2 blocks',
  },
];
---

<PageLayout
  metadata={{
    title: 'AstroBlocks - Component Showcase',
    description: 'A modern, production-ready component library for Astro landing pages.',
  }}
>
  <section class="border-b border-gray-800 bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="mb-4 text-sm font-semibold uppercase text-indigo-300">AstroBlocks</p>
        <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
          Astro component showcase
        </h1>
        <p class="mt-6 text-lg leading-8 text-gray-300">
          A local index for browsing the reusable Astro + TailwindCSS sections in this repository.
          Open a category, preview the variants, then copy the components you need.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((category) => (
        <a
          href={category.href}
          class="group rounded-lg border border-gray-800 bg-gray-900/60 p-6 transition-colors hover:border-indigo-400 hover:bg-gray-900"
        >
          <div class="flex items-start justify-between gap-4">
            <h2 class="text-xl font-semibold text-white">{category.title}</h2>
            <span class="shrink-0 rounded-full bg-gray-800 px-3 py-1 text-xs font-medium text-gray-300">
              {category.count}
            </span>
          </div>
          <p class="mt-3 text-sm leading-6 text-gray-400">{category.description}</p>
          <span class="mt-6 inline-flex text-sm font-semibold text-indigo-300 group-hover:text-indigo-200">
            View blocks
          </span>
        </a>
      ))}
    </div>
  </section>
</PageLayout>
